{
  "data-source": {
    "database-type": "mssql",
    "connection-string": "@env('DATABASE_CONNECTION_STRING')"
  },
  "runtime": {
    "rest": {
      "enabled": true,
      "path": "/rest"
    },
    "graphql": {
      "enabled": false
    },
    "host": {
      "mode": "production",
      "authentication": {
        "provider": "StaticWebApps"
      }
    }
  },
  "entities": {
    "guitar_brands": {
      "source": "dbo.guitar_brands",
      "permissions": [
        {
          "role": "anonymous",
          "actions": ["read"]
        }
      ]
    }
  }
}
